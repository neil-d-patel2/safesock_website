            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/neil/Dev/safesock/node_modules/.pnpm/prettier@3.8.1/node_modules/prettier/node_modules:/Users/neil/Dev/safesock/node_modules/.pnpm/prettier@3.8.1/node_modules:/Users/neil/Dev/safesock/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/neil/Dev/safesock/node_modules/.pnpm/prettier@3.8.1/node_modules/prettier/node_modules:/Users/neil/Dev/safesock/node_modules/.pnpm/prettier@3.8.1/node_modules:/Users/neil/Dev/safesock/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../prettier/bin/prettier.cjs" "$@"
else
  exec node  "$basedir/../../../prettier/bin/prettier.cjs" "$@"
fi
